# Copy this file to .env and fill in real values.
# Never commit .env to git.

# --- Database ---
# Get this from your Neon dashboard (neon.tech) → your project → Connection Details
# It will look like: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# Local Docker alternative (only if you have Docker Desktop installed):
#   DATABASE_URL=postgresql://fda_rag:fda_rag@localhost:5432/fda_rag
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Google Gemini (free tier — get key at aistudio.google.com) ---
GEMINI_API_KEY=AIza...

# --- Voyage AI (embeddings + reranker) ---
VOYAGE_API_KEY=pa-...

# --- LangSmith (tracing) ---
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=fda-rag

# --- Optional: set to "true" to enable LangSmith tracing ---
LANGCHAIN_TRACING_V2=false
